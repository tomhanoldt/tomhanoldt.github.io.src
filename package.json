{
  "name": "next-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "bun run lint:eslint && bun run lint:mdx-yaml && bun run ts:check",
    "lint:eslint": "eslint",
    "lint:fix": "eslint --fix .",
    "lint:mdx-yaml": "node scripts/check-frontmatter.js",
    "ts:check": "tsc --noEmit --pretty false --skipLibCheck",
    "export": "next build && bun run generate-sitemap",
    "generate-sitemap": "bun scripts/generate-sitemap.js",
    "test": "bun test",
    "smoke-test": "bun scripts/smoke-test.js",
    "clean": "rm -f .next/dev/lock && rm -rf .next"
  },
  "dependencies": {
    "@heroicons/react": "2.2.0",
    "gray-matter": "4.0.3",
    "next": "16.2.10",
    "next-mdx-remote": "6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-autolink-headings": "7.1.0",
    "rehype-pretty-code": "0.14.3",
    "rehype-slug": "6.0.0",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "shiki": "4.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "prettier": "3.9.4",
    "serve": "14.2.6",
    "tailwindcss": "4.3.2",
    "turndown": "7.2.4",
    "typescript": "7.0.2"
  }
}
